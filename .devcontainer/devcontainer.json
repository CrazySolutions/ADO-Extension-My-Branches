{
  "name": "Extension dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:18",
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code",
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot"
      ]
    }
  },
  "secrets": {
    "ANTHROPIC_API_KEY": {
      "description": "Your Anthropic API key",
      "documentationUrl": "https://console.anthropic.com"
    }
  }
}
